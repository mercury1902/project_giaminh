import { describe, it, expect, vi, beforeEach } from 'vitest';
import { getRAGContext, clearRAGCache } from '../services/rag-service.js';
import { wikipediaService } from '../services/wikipedia-service.js';

vi.mock('../services/wikipedia-service.js');

const mockWikipediaService = vi.mocked(wikipediaService);

describe('RAG Service', () => {
  beforeEach(() => {
    vi.clearAllMocks();
    clearRAGCache();
    mockWikipediaService.search.mockResolvedValue({ pages: [] });
    mockWikipediaService.getSummary.mockResolvedValue(null);
  });

  describe('getRAGContext() - Basic Functionality', () => {
    it('returns object with content and meta properties', async () => {
      const result = await getRAGContext('Ngô Quyền');
      expect(result).toHaveProperty('content');
      expect(result).toHaveProperty('meta');
      expect(typeof result.content).toBe('string');
      expect(typeof result.meta).toBe('object');
    });

    it('filters relevant events by query keywords', async () => {
      const result = await getRAGContext('Ngô Quyền');
      expect(result.content).toContain('Ngô Quyền chiến thắng Bạch Đằng');
      expect(result.content).toContain('Sự kiện liên quan từ dữ liệu lịch sử Việt Nam');
      expect(mockWikipediaService.search).toHaveBeenCalled();
    });

    it('includes Wikipedia summaries when available', async () => {
      mockWikipediaService.search.mockResolvedValueOnce({
        pages: [{ title: 'Ngô Quyền' }]
      });
      mockWikipediaService.getSummary.mockResolvedValueOnce({
        title: 'Ngô Quyền',
        description: 'Leader who defeated Southern Han'
      });

      const result = await getRAGContext('Ngô Quyền');
      expect(result.content).toContain('• Ngô Quyền: Leader who defeated Southern Han');
      expect(result.meta.success).toBe(true);
      expect(result.meta.strategy).toBeGreaterThan(0);
    });

    it('handles no relevant events gracefully', async () => {
      const result = await getRAGContext('nonexistent');
      expect(result.content).toContain('Không tìm thấy sự kiện phù hợp.');
      expect(result.meta).toHaveProperty('success');
    });
  });

  describe('Multi-Tier Search Strategies', () => {
    it('Strategy 1: Primary search succeeds', async () => {
      mockWikipediaService.search.mockResolvedValueOnce({
        pages: [{ title: 'Lý Thái Tổ' }]
      });
      mockWikipediaService.getSummary.mockResolvedValueOnce({
        title: 'Lý Thái Tổ',
        description: 'Founder of Lý dynasty'
      });

      const result = await getRAGContext('Lý Thái Tổ');

      expect(result.meta.success).toBe(true);
      expect(result.meta.strategy).toBe(1);
      expect(result.meta.reason).toBe('Primary search');
      expect(result.content).toContain('Lý Thái Tổ');
      expect(mockWikipediaService.search).toHaveBeenCalledWith('Lý Thái Tổ', 3);
    });

    it('Strategy 2: Keyword search succeeds when primary fails', async () => {
      // Primary search fails
      mockWikipediaService.search.mockResolvedValueOnce({ pages: [] });

      // Keyword search succeeds (second call)
      mockWikipediaService.search.mockResolvedValueOnce({
        pages: [{ title: 'Trần Hưng Đạo' }]
      });
      mockWikipediaService.getSummary.mockResolvedValueOnce({
        title: 'Trần Hưng Đạo',
        description: 'Famous general'
      });

      const result = await getRAGContext('chiến thắng Trần Hưng Đạo');

      expect(result.meta.success).toBe(true);
      expect(result.meta.strategy).toBe(2);
      expect(result.meta.reason).toBe('Keyword extraction');
      expect(mockWikipediaService.search).toHaveBeenCalledTimes(2); // primary + keyword
    });

    it('Strategy 3: Diacritic removal succeeds when strategies 1-2 fail', async () => {
      // Use a simple query with diacritics: "Trần Hưng Đạo"
      // Keywords after stopword removal: "trần", "hưng", "đạo" (3 keywords)

      // Primary search fails
      mockWikipediaService.search.mockResolvedValueOnce({ pages: [] });

      // Keyword searches fail (3 keywords)
      mockWikipediaService.search.mockResolvedValueOnce({ pages: [] }); // "trần"
      mockWikipediaService.search.mockResolvedValueOnce({ pages: [] }); // "hưng"
      mockWikipediaService.search.mockResolvedValueOnce({ pages: [] }); // "đạo"

      // Simplified search succeeds (diacritics removed: "Trần Hưng Đạo" → "Tran Hung Dao")
      mockWikipediaService.search.mockResolvedValueOnce({
        pages: [{ title: 'Tran Hung Dao' }]
      });
      mockWikipediaService.getSummary.mockResolvedValueOnce({
        title: 'Tran Hung Dao',
        description: 'Famous Vietnamese general'
      });

      const result = await getRAGContext('Trần Hưng Đạo');

      expect(result.meta.success).toBe(true);
      expect(result.meta.strategy).toBe(3);
      expect(result.meta.reason).toBe('Diacritics removed');
    });

    it('All strategies fail: returns metadata with success: false', async () => {
      mockWikipediaService.search.mockResolvedValue({ pages: [] });

      const result = await getRAGContext('completely unknown query xyz');

      expect(result.meta.success).toBe(false);
      expect(result.meta.strategy).toBe(0);
      expect(result.content).toContain('Không tìm thấy thông tin Wikipedia phù hợp.');
    });
  });

  describe('Edge Cases', () => {
    it('handles empty query', async () => {
      const result = await getRAGContext('');
      expect(result).toHaveProperty('content');
      expect(result).toHaveProperty('meta');
    });

    it('handles query with only stopwords', async () => {
      const result = await getRAGContext('là của được có');
      expect(result.meta).toHaveProperty('success');
    });

    it('handles Wikipedia API error gracefully', async () => {
      mockWikipediaService.search.mockRejectedValue(new Error('Wiki API error'));

      const result = await getRAGContext('Ngô Quyền');
      expect(result.content).toContain('Không tìm thấy thông tin Wikipedia phù hợp.');
      expect(result.content).toContain('Ngô Quyền'); // events still work
      expect(result.meta.success).toBe(false);
    });

    it('handles getSummary error gracefully', async () => {
      mockWikipediaService.search.mockResolvedValueOnce({
        pages: [{ title: 'Test' }]
      });
      mockWikipediaService.getSummary.mockRejectedValue(new Error('Summary error'));

      const result = await getRAGContext('test query');
      expect(result.meta.success).toBe(false); // No valid summaries
    });
  });

  describe('Caching with {content, meta} format', () => {
    it('returns cached {content, meta} object on second call', async () => {
      mockWikipediaService.search.mockResolvedValueOnce({
        pages: [{ title: 'Ngô Quyền' }]
      });
      mockWikipediaService.getSummary.mockResolvedValueOnce({
        title: 'Ngô Quyền',
        description: 'Leader'
      });

      const result1 = await getRAGContext('Ngô Quyền');
      const result2 = await getRAGContext('Ngô Quyền');

      expect(result1).toEqual(result2);
      expect(result2).toHaveProperty('content');
      expect(result2).toHaveProperty('meta');
      expect(mockWikipediaService.search).toHaveBeenCalledTimes(1); // Only called once
    });

    it('cache preserves metadata structure', async () => {
      mockWikipediaService.search.mockResolvedValueOnce({
        pages: [{ title: 'Test' }]
      });
      mockWikipediaService.getSummary.mockResolvedValueOnce({
        title: 'Test',
        description: 'Desc'
      });

      const result1 = await getRAGContext('test');
      const result2 = await getRAGContext('test');

      expect(result2.meta).toEqual(result1.meta);
      expect(result2.meta.success).toBe(true);
      expect(result2.meta.strategy).toBe(result1.meta.strategy);
    });
  });

  describe('Metadata Structure', () => {
    it('success metadata includes strategy, articles, and reason', async () => {
      mockWikipediaService.search.mockResolvedValueOnce({
        pages: [{ title: 'Article1' }, { title: 'Article2' }]
      });
      mockWikipediaService.getSummary.mockResolvedValueOnce({
        title: 'Article1',
        description: 'Desc1'
      });
      mockWikipediaService.getSummary.mockResolvedValueOnce({
        title: 'Article2',
        description: 'Desc2'
      });

      const result = await getRAGContext('test');

      expect(result.meta.success).toBe(true);
      expect(result.meta.strategy).toBeGreaterThan(0);
      expect(result.meta.articles).toBe(2);
      expect(result.meta.reason).toBeTruthy();
    });

    it('failure metadata has success: false and strategy: 0', async () => {
      mockWikipediaService.search.mockResolvedValue({ pages: [] });

      const result = await getRAGContext('xyz unknown');

      expect(result.meta.success).toBe(false);
      expect(result.meta.strategy).toBe(0);
    });
  });

  describe('Vietnamese Language Processing', () => {
    it('processes Vietnamese keywords correctly', async () => {
      mockWikipediaService.search.mockResolvedValueOnce({ pages: [] });
      mockWikipediaService.search.mockResolvedValueOnce({
        pages: [{ title: 'Đổi Mới' }]
      });
      mockWikipediaService.getSummary.mockResolvedValueOnce({
        title: 'Đổi Mới',
        description: 'Economic reform'
      });

      const result = await getRAGContext('chính sách Đổi Mới của Việt Nam');

      // Should extract "chính", "sách", "Đổi", "Mới", "Việt", "Nam" (excluding stopwords)
      expect(result.meta.success).toBe(true);
      expect(mockWikipediaService.search).toHaveBeenCalledTimes(2); // primary + keywords
    });

    it('handles Vietnamese diacritics in queries', async () => {
      mockWikipediaService.search.mockResolvedValueOnce({ pages: [] });
      mockWikipediaService.search.mockResolvedValueOnce({ pages: [] });
      mockWikipediaService.search.mockResolvedValueOnce({
        pages: [{ title: 'Trần' }]
      });
      mockWikipediaService.getSummary.mockResolvedValueOnce({
        title: 'Trần',
        description: 'Dynasty'
      });

      const result = await getRAGContext('Triều đại Trần');

      // Strategy 3 should remove diacritics: "Triều đại Trần" → "Trieu dai Tran"
      expect(mockWikipediaService.search).toHaveBeenCalledTimes(3);
    });
  });
});
